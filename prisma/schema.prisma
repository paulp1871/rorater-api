generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  robloxId    BigInt    @id @map("roblox_id")
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  ratingsGiven    Rating[] @relation("rater")
  ratingsReceived Rating[] @relation("rated")

  @@map("users")
}

model Rating {
  id        BigInt   @id @default(autoincrement())
  raterId   BigInt   @map("rater_id")
  ratedId   BigInt   @map("rated_id")
  score     Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  rater User @relation("rater", fields: [raterId], references: [robloxId])
  rated User @relation("rated", fields: [ratedId], references: [robloxId])

  @@unique([raterId, ratedId])
  @@index([ratedId, createdAt])
  @@map("ratings")
}