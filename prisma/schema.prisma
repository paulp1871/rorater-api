generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  robloxId    BigInt    @id @map("roblox_id")
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  ratingsGiven    Rating[] @relation("rater")
  ratingsReceived Rating[] @relation("rated")

  @@map("users")
}

model Rating {
  id        BigInt   @id @default(autoincrement())
  raterId   BigInt   @map("rater_id")
  ratedId   BigInt   @map("rated_id")
  score     Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  rater User @relation("rater", fields: [raterId], references: [robloxId])
  rated User @relation("rated", fields: [ratedId], references: [robloxId])

  @@unique([raterId, ratedId])
  // Serves ratedId lookups ordered recent-first: getUserRatingStats and the
  // top-rated / recently-rated leaderboards. The @@unique index above is
  // prefixed on raterId and cannot serve ratedId-only queries.
  @@index([ratedId, createdAt])
  // NOTE: two CHECK constraints also exist on this table (score 1..5 and
  // rater_id <> rated_id). Prisma cannot model CHECK constraints, so they live
  // only in the migration SQL — preserve them when editing future migrations.
  @@map("ratings")
}